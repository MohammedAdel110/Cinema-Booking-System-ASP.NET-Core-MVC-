@model CinemaBooking.Application.Features.ShowTimes.CreateShowTimeCommand
@{
    ViewData["Title"] = "Add New ShowTime";
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <div>
        <h2 class="fw-bold mb-0 text-dark">Add New ShowTime</h2>
        <p class="text-muted mb-0">Schedule a movie screening</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm hover-lift">
        <i class="fa-solid fa-arrow-left me-2"></i> Back to List
    </a>
</div>

<div class="row" data-aos="fade-up">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post">
                    <div class="row g-4">
                        
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="MovieId" class="form-select" asp-items="ViewBag.Movies">
                                    <option value="">-- Select Movie --</option>
                                </select>
                                <label asp-for="MovieId"><i class="fa-solid fa-film me-2"></i> Movie</label>
                                <span asp-validation-for="MovieId" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="HallId" class="form-select" asp-items="ViewBag.Halls">
                                    <option value="">-- Select Hall --</option>
                                </select>
                                <label asp-for="HallId"><i class="fa-solid fa-door-open me-2"></i> Hall</label>
                                <span asp-validation-for="HallId" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="StartTime" class="form-control" type="datetime-local" />
                                <label asp-for="StartTime"><i class="fa-regular fa-clock me-2"></i> Date & Time</label>
                                <span asp-validation-for="StartTime" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="TicketPrice" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                <label asp-for="TicketPrice"><i class="fa-solid fa-money-bill me-2"></i> Ticket Price ($)</label>
                                <span asp-validation-for="TicketPrice" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" class="btn btn-primary px-5 py-2 w-100 fw-bold fs-6 shadow-lg hover-lift">
                                <i class="fa-solid fa-save me-2"></i> Schedule ShowTime
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
