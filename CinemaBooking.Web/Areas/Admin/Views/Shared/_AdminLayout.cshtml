<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Toastr -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.5/css/dataTables.bootstrap5.min.css" />
    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <!-- Pace.js -->
    <script src="https://cdn.jsdelivr.net/npm/pace-js@latest/pace.min.js"></script>
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="container-fluid p-0">
        <div class="row g-0">
            <!-- Sidebar -->
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="position-sticky sidebar-sticky">
                    <a class="navbar-brand text-white fw-bold d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="/images/logo_cropped.png" alt="CinemaBooking Logo" style="height: 50px; object-fit: contain; margin: -5px 0;" />
                    </a>
                    <ul class="nav flex-column mt-3">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                                <i class="fa-solid fa-chart-pie fa-fw"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Movies" ? "active" : "")" asp-controller="Movies" asp-action="Index">
                                <i class="fa-solid fa-video fa-fw"></i> Movies
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")" asp-controller="Categories" asp-action="Index">
                                <i class="fa-solid fa-tags fa-fw"></i> Categories
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cinemas" ? "active" : "")" asp-controller="Cinemas" asp-action="Index">
                                <i class="fa-solid fa-building fa-fw"></i> Cinemas
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Halls" ? "active" : "")" asp-controller="Halls" asp-action="Index">
                                <i class="fa-solid fa-door-open fa-fw"></i> Halls
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ShowTimes" ? "active" : "")" asp-controller="ShowTimes" asp-action="Index">
                                <i class="fa-solid fa-clock fa-fw"></i> ShowTimes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bookings" ? "active" : "")" asp-controller="Bookings" asp-action="Index">
                                <i class="fa-solid fa-ticket fa-fw"></i> Bookings
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-0">
                <!-- Top Navbar -->
                <header class="admin-navbar d-flex justify-content-between align-items-center p-3 mb-4">
                    <div class="d-flex align-items-center">
                        <button class="btn btn-action d-md-none me-3" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu">
                            <i class="fa-solid fa-bars"></i>
                        </button>
                        <h5 class="mb-0 fw-bold text-muted d-none d-md-block">@ViewData["Title"]</h5>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="dropdown">
                            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark fw-medium" data-bs-toggle="dropdown">
                                <img src="https://ui-avatars.com/api/?name=@User.Identity?.Name&background=2563EB&color=fff&rounded=true" alt="User" width="36" height="36" class="rounded-circle me-2">
                                @User.Identity?.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <li><a class="dropdown-item" href="/"><i class="fa-solid fa-globe fa-fw me-2"></i> Public Site</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form class="px-3 py-1" asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                                        <button type="submit" class="btn btn-danger btn-sm w-100"><i class="fa-solid fa-sign-out-alt"></i> Sign out</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </header>

                <div class="container-fluid px-4 pb-5 fade-enter-active">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.5/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.5/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Initialize AOS
        AOS.init({ duration: 800, once: true });

        // Initialize DataTables globally
        $(document).ready(function () {
            $('.dataTable').DataTable({
                "language": {
                    "emptyTable": "<div class='empty-state'><i class='fa-regular fa-folder-open empty-state-icon'></i><div class='empty-state-title'>No records found</div><div class='empty-state-text'>There is no data to display in this table.</div></div>"
                },
                "dom": '<"row align-items-center mb-3"<"col-md-6"l><"col-md-6"f>>rt<"row align-items-center mt-3"<"col-md-6"i><"col-md-6"p>>'
            });
        });

        // Toastr Configuration
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "showDuration": "300",
            "hideDuration": "1000",
            "timeOut": "5000"
        };

        @if (TempData["SuccessMessage"] != null)
        {
            <text>toastr.success('@TempData["SuccessMessage"]');</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <text>toastr.error('@TempData["ErrorMessage"]');</text>
        }

        // Global Delete Confirmation
        function confirmDelete(formId) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: '<i class="fa-solid fa-trash"></i> Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById(formId).submit();
                }
            })
        }
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
