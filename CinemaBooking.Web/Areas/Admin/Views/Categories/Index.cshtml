@model IEnumerable<CinemaBooking.Application.DTOs.CategoryDto>
@{
    ViewData["Title"] = "Categories Management";
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <div>
        <h2 class="fw-bold mb-0 text-dark">Categories</h2>
        <p class="text-muted mb-0">Manage movie genres and categories</p>
    </div>
    <a asp-action="Create" class="btn btn-primary shadow-sm hover-lift">
        <i class="fa-solid fa-plus me-2"></i> Add New Category
    </a>
</div>

<div class="card shadow-sm border-0" data-aos="fade-up">
    <div class="card-body p-0">
        <div class="table-responsive p-4">
            <table class="table dataTable table-hover align-middle w-100">
                <thead>
                    <tr>
                        <th width="80">ID</th>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td>
                                <span class="badge bg-secondary">#@item.Id</span>
                            </td>
                            <td>
                                <div class="fw-bold text-dark fs-6"><i class="fa-solid fa-tags text-primary opacity-50 me-2"></i>@item.Name</div>
                            </td>
                            <td>
                                <div class="text-muted text-truncate" style="max-width: 300px;">
                                    @item.Description
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-action edit" data-bs-toggle="tooltip" title="Edit Category">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    <form id="delete-form-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                        <button type="button" onclick="confirmDelete('delete-form-@item.Id')" class="btn btn-action delete" data-bs-toggle="tooltip" title="Delete Category">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })
        });
    </script>
}
