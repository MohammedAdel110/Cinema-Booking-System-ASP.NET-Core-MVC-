@model IEnumerable<CinemaBooking.Application.DTOs.MovieDto>
@{
    ViewData["Title"] = "Movies Management";
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <div>
        <h2 class="fw-bold mb-0 text-dark">Movies</h2>
        <p class="text-muted mb-0">Manage all movies in the cinema</p>
    </div>
    <a asp-action="Create" class="btn btn-primary shadow-sm hover-lift">
        <i class="fa-solid fa-plus me-2"></i> Add New Movie
    </a>
</div>

<div class="card shadow-sm border-0" data-aos="fade-up">
    <div class="card-body p-0">
        <div class="table-responsive p-4">
            <table class="table dataTable table-hover align-middle w-100">
                <thead>
                    <tr>
                        <th width="80">Poster</th>
                        <th>Title & Category</th>
                        <th>Duration</th>
                        <th>Release Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.PosterUrl)) {
                                    <div class="position-relative" style="width: 60px; height: 90px; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                                        <img src="@item.PosterUrl" alt="Poster" class="w-100 h-100 object-fit-cover" />
                                    </div>
                                } else {
                                    <div class="d-flex align-items-center justify-content-center bg-light text-muted" style="width: 60px; height: 90px; border-radius: 8px; border: 1px dashed #cbd5e1;">
                                        <i class="fa-solid fa-image fa-2x opacity-25"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-bold text-dark fs-6">@item.Title</div>
                                <span class="badge bg-primary-soft mt-1">@item.CategoryName</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center text-muted">
                                    <i class="fa-regular fa-clock me-2 text-warning"></i> @item.DurationMinutes mins
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center text-muted">
                                    <i class="fa-regular fa-calendar me-2 text-info"></i> @item.ReleaseDate.ToString("MMM dd, yyyy")
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-action edit" data-bs-toggle="tooltip" title="Edit Movie">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    <form id="delete-form-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                        <button type="button" onclick="confirmDelete('delete-form-@item.Id')" class="btn btn-action delete" data-bs-toggle="tooltip" title="Delete Movie">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })
        });
    </script>
}
