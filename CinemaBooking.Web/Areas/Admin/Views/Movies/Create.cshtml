@model CinemaBooking.Application.Features.Movies.CreateMovieCommand
@{
    ViewData["Title"] = "Add New Movie";
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <div>
        <h2 class="fw-bold mb-0 text-dark">Add New Movie</h2>
        <p class="text-muted mb-0">Create a new movie record in the system</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm hover-lift">
        <i class="fa-solid fa-arrow-left me-2"></i> Back to List
    </a>
</div>

<div class="row" data-aos="fade-up">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post" enctype="multipart/form-data" id="movieForm">
                    <div class="row g-4">
                        
                        <div class="col-md-12">
                            <div class="form-floating">
                                <input asp-for="Title" class="form-control" placeholder="Movie Title" />
                                <label asp-for="Title"><i class="fa-solid fa-heading me-2"></i> Movie Title</label>
                                <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="form-floating">
                                <textarea asp-for="Description" class="form-control" placeholder="Description" style="height: 120px"></textarea>
                                <label asp-for="Description"><i class="fa-solid fa-align-left me-2"></i> Description</label>
                                <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-floating">
                                <input asp-for="DurationMinutes" class="form-control" type="number" placeholder="Duration (mins)" />
                                <label asp-for="DurationMinutes"><i class="fa-solid fa-clock me-2"></i> Duration (mins)</label>
                                <span asp-validation-for="DurationMinutes" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-floating">
                                <input asp-for="ReleaseDate" class="form-control" type="date" placeholder="Release Date" />
                                <label asp-for="ReleaseDate"><i class="fa-solid fa-calendar me-2"></i> Release Date</label>
                                <span asp-validation-for="ReleaseDate" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-floating">
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                                    <option value="">-- Select Category --</option>
                                </select>
                                <label asp-for="CategoryId"><i class="fa-solid fa-tags me-2"></i> Category</label>
                                <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold"><i class="fa-solid fa-image me-2"></i> Upload Poster</label>
                            <div class="border rounded p-4 text-center" style="border: 2px dashed #cbd5e1 !important; background-color: #f8fafc;">
                                <div class="mb-3">
                                    <i class="fa-solid fa-cloud-arrow-up text-primary fa-3x"></i>
                                </div>
                                <input asp-for="PosterFile" class="form-control d-none" type="file" accept="image/*" id="posterUpload" />
                                <button type="button" class="btn btn-outline-primary mb-2" onclick="document.getElementById('posterUpload').click()">Choose Image</button>
                                <p class="text-muted small mb-0" id="fileNameDisplay">No file chosen. Supported formats: JPG, PNG.</p>
                                <span asp-validation-for="PosterFile" class="text-danger small mt-2 d-block"></span>
                                
                                <div id="imagePreviewContainer" class="mt-3 d-none">
                                    <img id="imagePreview" src="#" alt="Preview" class="img-thumbnail" style="max-height: 200px; border-radius: 8px;" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" class="btn btn-primary px-5 py-2 w-100 fw-bold fs-6 shadow-lg hover-lift">
                                <i class="fa-solid fa-save me-2"></i> Save Movie
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('posterUpload').addEventListener('change', function(e) {
            var fileName = e.target.files[0]?.name;
            var display = document.getElementById('fileNameDisplay');
            var preview = document.getElementById('imagePreview');
            var container = document.getElementById('imagePreviewContainer');
            
            if(fileName) {
                display.innerText = "Selected file: " + fileName;
                
                // Image preview
                var reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    container.classList.remove('d-none');
                }
                reader.readAsDataURL(e.target.files[0]);
            } else {
                display.innerText = "No file chosen. Supported formats: JPG, PNG.";
                container.classList.add('d-none');
                preview.src = "#";
            }
        });
    </script>
}
