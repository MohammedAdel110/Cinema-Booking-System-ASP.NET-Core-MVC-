@model CinemaBooking.Application.Features.Movies.MovieDetailsDto
@{
    ViewData["Title"] = Model.Title;
}

<div class="position-relative" style="margin-top: 56px;">
    <!-- Backdrop -->
    <div class="position-absolute w-100" style="height: 60vh; z-index: -1;">
        @if (!string.IsNullOrEmpty(Model.PosterUrl))
        {
            <div class="w-100 h-100" style="background-image: url('@Model.PosterUrl'); background-size: cover; background-position: center; filter: blur(20px) brightness(0.3); transform: scale(1.1);"></div>
        }
        else
        {
            <div class="w-100 h-100 bg-dark"></div>
        }
        <div class="position-absolute bottom-0 w-100" style="height: 100%; background: linear-gradient(to top, #0f172a 0%, transparent 100%);"></div>
    </div>

    <div class="container py-5">
        <div class="row pt-5">
            <!-- Poster -->
            <div class="col-lg-3 col-md-4 mb-5 mb-md-0" data-aos="fade-right">
                <div class="rounded-4 overflow-hidden shadow-lg border border-secondary border-opacity-25" style="aspect-ratio: 2/3;">
                    @if (!string.IsNullOrEmpty(Model.PosterUrl))
                    {
                        <img src="@Model.PosterUrl" class="w-100 h-100 object-fit-cover" alt="@Model.Title">
                    }
                    else
                    {
                        <div class="w-100 h-100 bg-secondary d-flex align-items-center justify-content-center">
                            <i class="fa-solid fa-film fa-4x text-white-50"></i>
                        </div>
                    }
                </div>
            </div>

            <!-- Details -->
            <div class="col-lg-9 col-md-8 text-white" data-aos="fade-left">
                <h1 class="display-3 fw-bold mb-3">@Model.Title</h1>
                <div class="d-flex flex-wrap align-items-center gap-3 mb-4 text-white-50">
                    <span class="badge bg-primary text-white px-3 py-2 fs-6">@Model.CategoryName</span>
                    <span class="d-flex align-items-center"><i class="fa-solid fa-clock text-warning me-2"></i> @Model.DurationMinutes Minutes</span>
                    <span class="d-flex align-items-center"><i class="fa-solid fa-calendar-alt text-info me-2"></i> @Model.ReleaseDate.ToString("MMMM dd, yyyy")</span>
                </div>
                
                <h4 class="fw-bold mb-3 mt-5">Overview</h4>
                <p class="lead text-white-50" style="line-height: 1.8;">
                    @Model.Description
                </p>
                
                <div class="d-flex gap-3 mt-5">
                    <button class="btn btn-outline-light rounded-pill px-4 hover-lift d-flex align-items-center gap-2 border-2">
                        <i class="fa-regular fa-circle-play"></i> Watch Trailer
                    </button>
                    <button class="btn btn-outline-danger rounded-circle border-2" style="width: 48px; height: 48px;" data-bs-toggle="tooltip" title="Add to Favorites">
                        <i class="fa-regular fa-heart"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5 mt-4">
    <h3 class="fw-bold text-white mb-4 border-bottom border-secondary border-opacity-50 pb-3" data-aos="fade-up">Available Showtimes</h3>
    
    @if (!Model.ShowTimesByCinema.Any())
    {
        <div class="empty-state bg-dark rounded-4 shadow border border-secondary border-opacity-25" data-aos="fade-up">
            <i class="fa-regular fa-calendar-xmark empty-state-icon text-warning opacity-75"></i>
            <h4 class="text-white fw-bold">No Upcoming Showtimes</h4>
            <p class="text-white-50">There are currently no scheduled screenings for this movie. Check back later!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var cinema in Model.ShowTimesByCinema)
            {
                <div class="col-12" data-aos="fade-up">
                    <div class="card bg-dark border border-secondary border-opacity-25 rounded-4 overflow-hidden">
                        <div class="card-header bg-black bg-opacity-25 border-bottom border-secondary border-opacity-25 py-3">
                            <h5 class="mb-0 text-white fw-bold d-flex align-items-center">
                                <i class="fa-solid fa-building text-primary me-3 fs-4"></i> @cinema.Key
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="d-flex flex-wrap gap-3">
                                @foreach (var show in cinema.Value)
                                {
                                    <a asp-controller="Bookings" asp-action="Book" asp-route-showTimeId="@show.Id" class="text-decoration-none">
                                        <div class="showtime-pill d-flex flex-column align-items-center justify-content-center bg-black bg-opacity-50 border border-secondary border-opacity-50 rounded-3 p-3 hover-lift text-white transition-all">
                                            <span class="fw-bold fs-5 mb-1">@show.StartTime.ToString("hh:mm tt")</span>
                                            <span class="text-white-50 small mb-2">@show.StartTime.ToString("MMM dd")</span>
                                            <span class="badge bg-success-soft text-success border border-success rounded-pill px-3">@show.TicketPrice.ToString("C")</span>
                                        </div>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <style>
        .showtime-pill { min-width: 120px; }
        .showtime-pill:hover { background-color: var(--bs-primary) !important; border-color: var(--bs-primary) !important; box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3); }
        .showtime-pill:hover .text-white-50 { color: rgba(255,255,255,0.8) !important; }
        .showtime-pill:hover .badge { background-color: white !important; color: var(--bs-primary) !important; border-color: white !important; }
    </style>
    <script>
        $(document).ready(function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })
        });
    </script>
}
