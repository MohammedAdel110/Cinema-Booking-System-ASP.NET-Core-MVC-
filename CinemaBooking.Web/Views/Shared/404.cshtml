@{
    ViewData["Title"] = "Page Not Found";
}

<div class="position-relative min-vh-100 d-flex align-items-center justify-content-center" style="margin-top: -80px;">
    <!-- Background image and overlay -->
    <div class="position-absolute w-100 h-100 z-index-n1">
        <div class="w-100 h-100" style="background: radial-gradient(circle at center, #1e1b4b 0%, #0f172a 100%);"></div>
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-black opacity-50"></div>
    </div>

    <div class="container text-center" data-aos="zoom-in">
        <div class="mb-5 position-relative d-inline-block">
            <h1 class="display-1 fw-bold text-white mb-0" style="font-size: 10rem; text-shadow: 0 10px 30px rgba(0,0,0,0.5);">404</h1>
            <i class="fa-solid fa-ghost position-absolute text-primary" style="font-size: 4rem; top: 50%; left: 50%; transform: translate(-50%, -50%); opacity: 0.1;"></i>
        </div>
        <h2 class="fw-bold text-white mb-3">Oops! Scene Missing</h2>
        <p class="lead text-white-50 mb-5 max-w-md mx-auto" style="max-width: 500px;">
            @ViewBag.ErrorMessage
            It looks like this page was left on the cutting room floor. Let's get you back to the main feature.
        </p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold hover-lift shadow-lg">
            <i class="fa-solid fa-house me-2"></i> Return Home
        </a>
    </div>
</div>
