@model CinemaBooking.Application.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="position-relative min-vh-100 d-flex align-items-center justify-content-center" style="margin-top: -80px;">
    <!-- Background image and overlay -->
    <div class="position-absolute w-100 h-100 z-index-n1">
        <img src="https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?q=80&w=2070&auto=format&fit=crop" class="w-100 h-100 object-fit-cover" style="filter: brightness(0.3);" alt="Cinema Background">
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-black opacity-75"></div>
    </div>

    <div class="container py-5" data-aos="fade-up">
        <div class="row justify-content-center">
            <div class="col-md-10 col-lg-7 col-xl-6">
                <div class="card bg-dark bg-opacity-75 border border-secondary border-opacity-25 shadow-lg rounded-4 overflow-hidden" style="backdrop-filter: blur(20px);">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-5">
                            <h2 class="fw-bold text-white mb-2">Create an Account</h2>
                            <p class="text-white-50">Join CinemaPro and book your tickets faster.</p>
                        </div>

                        <form asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                            
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <input asp-for="FirstName" class="form-control bg-black bg-opacity-50 border-secondary text-white" aria-required="true" placeholder="First Name" />
                                        <label asp-for="FirstName" class="text-white-50">First Name</label>
                                        <span asp-validation-for="FirstName" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <input asp-for="LastName" class="form-control bg-black bg-opacity-50 border-secondary text-white" aria-required="true" placeholder="Last Name" />
                                        <label asp-for="LastName" class="text-white-50">Last Name</label>
                                        <span asp-validation-for="LastName" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Email" class="form-control bg-black bg-opacity-50 border-secondary text-white" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                                <label asp-for="Email" class="text-white-50"><i class="fa-regular fa-envelope me-2"></i> Email Address</label>
                                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                            </div>
                            
                            <div class="form-floating mb-3">
                                <input asp-for="Password" class="form-control bg-black bg-opacity-50 border-secondary text-white" autocomplete="new-password" aria-required="true" placeholder="password" />
                                <label asp-for="Password" class="text-white-50"><i class="fa-solid fa-lock me-2"></i> Password</label>
                                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="form-floating mb-4">
                                <input asp-for="ConfirmPassword" class="form-control bg-black bg-opacity-50 border-secondary text-white" autocomplete="new-password" aria-required="true" placeholder="password" />
                                <label asp-for="ConfirmPassword" class="text-white-50"><i class="fa-solid fa-check-double me-2"></i> Confirm Password</label>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <button id="register-submit" type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold hover-lift mb-4 shadow-lg">Sign Up Now</button>
                            
                            <div class="text-center">
                                <p class="text-white-50 small mb-0">Already have an account? <a asp-action="Login" class="text-primary text-decoration-none fw-bold ms-1">Log In</a></p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
