@model CinemaBooking.Application.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6" data-aos="fade-up">
            <div class="card bg-dark bg-opacity-75 border border-secondary border-opacity-25 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-black bg-opacity-50 border-bottom border-secondary border-opacity-25 p-4 d-flex align-items-center gap-3">
                    <a asp-action="Profile" class="btn btn-action bg-secondary text-white rounded-circle"><i class="fa-solid fa-arrow-left"></i></a>
                    <h4 class="fw-bold text-white mb-0">Change Password</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    
                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="OldPassword" class="form-control bg-black bg-opacity-50 border-secondary text-white" aria-required="true" placeholder="Old Password" />
                            <label asp-for="OldPassword" class="text-white-50"><i class="fa-solid fa-lock-open me-2"></i> Current Password</label>
                            <span asp-validation-for="OldPassword" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="NewPassword" class="form-control bg-black bg-opacity-50 border-secondary text-white" aria-required="true" placeholder="New Password" />
                            <label asp-for="NewPassword" class="text-white-50"><i class="fa-solid fa-lock me-2"></i> New Password</label>
                            <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
                            <div class="form-text text-white-50 mt-2">Password must be at least 6 characters long.</div>
                        </div>

                        <div class="form-floating mb-5">
                            <input asp-for="ConfirmPassword" class="form-control bg-black bg-opacity-50 border-secondary text-white" aria-required="true" placeholder="Confirm Password" />
                            <label asp-for="ConfirmPassword" class="text-white-50"><i class="fa-solid fa-check-double me-2"></i> Confirm New Password</label>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold hover-lift shadow-lg">
                            <i class="fa-solid fa-save me-2"></i> Update Password
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
