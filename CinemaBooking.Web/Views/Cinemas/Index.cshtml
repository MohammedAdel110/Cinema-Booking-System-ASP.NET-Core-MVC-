@model IEnumerable<CinemaBooking.Application.DTOs.CinemaDto>
@{
    ViewData["Title"] = "Our Cinemas";
}

<div class="text-center mb-5">
    <h2 class="display-4">Our Cinemas</h2>
    <p class="lead text-muted">Experience movies in the best halls across the country.</p>
</div>

<div class="row row-cols-1 row-cols-md-2 g-4">
    @foreach (var cinema in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <h4 class="card-title text-primary"><i class="bi bi-building"></i> @cinema.Name</h4>
                    <p class="card-text text-muted fs-5"><i class="bi bi-geo-alt"></i> @cinema.Location</p>
                </div>
            </div>
        </div>
    }
</div>
