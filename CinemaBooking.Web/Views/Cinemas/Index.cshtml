@model IEnumerable<CinemaBooking.Application.DTOs.CinemaDto>
@{
    ViewData["Title"] = "Our Cinemas";
}

<div class="container py-5 mt-5">
    <div class="row mb-5" data-aos="fade-down">
        <div class="col-12">
            <h1 class="fw-bold text-white mb-2 display-5">Our Cinemas</h1>
            <p class="text-white-50 lead mb-0">Experience movies in the best halls across the country.</p>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var cinema in Model)
        {
            <div class="col" data-aos="fade-up">
                <div class="card h-100 shadow-lg border border-secondary border-opacity-25 bg-dark hover-lift">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="bg-primary bg-opacity-10 rounded-circle p-3 d-flex align-items-center justify-content-center text-primary" style="width: 60px; height: 60px;">
                                <i class="fa-solid fa-building fs-3"></i>
                            </div>
                            <h4 class="card-title text-white fw-bold mb-0">@cinema.Name</h4>
                        </div>
                        <p class="card-text text-white-50 mb-4 d-flex align-items-center gap-2">
                            <i class="fa-solid fa-location-dot text-primary"></i> @cinema.Location
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
